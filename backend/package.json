{
  "name": "dainna-backend",
  "version": "1.0.0",
  "description": "Express backend server for Dainna 2.0",
  "main": "dist/server.js",
  "prisma": {
    "schema": "../database/schema.prisma"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "npx prisma generate --schema=../database/schema.prisma && tsc",
    "start": "node dist/server.js",
    "prisma:generate": "npx prisma generate --schema=../database/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema=../database/schema.prisma",
    "db:migrate-data": "node migrate-data.js"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@prisma/adapter-pg": "^5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "pg": "^8.22.0",
    "prisma": "^5.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
