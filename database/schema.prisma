  user_master_invoice_master_addedbyTouser_master                   User?                    @relation("invoice_master_addedbyTouser_master", fields: [addedby], references: [userId], onDelete: Restrict, onUpdate: Restrict, map: "invoice_master_ibfk_4")
  payment_gateway_master                                            payment_gateway_master?  @relation(fields: [pg_id], references: [pg_id], onDelete: Restrict, onUpdate: Restrict, map: "invoice_master_ibfk_5")
  state_master                                                      state_master?            @relation(fields: [state_id], references: [state_id], onDelete: Restrict, onUpdate: Restrict, map: "invoice_master_ibfk_6")
  adv_payment_master                                                adv_payment_master?      @relation(fields: [adv_pay_id], references: [adv_pay_id], onDelete: Restrict, onUpdate: Restrict, map: "invoice_master_ibfk_7")
  user_master_invoice_master_agent_payment_received_byTouser_master User?                    @relation("invoice_master_agent_payment_received_byTouser_master", fields: [agent_payment_received_by], references: [userId], onDelete: Restrict, onUpdate: Restrict, map: "invoice_master_ibfk_8")
  user_master_invoice_master_adv_payment_received_byTouser_master   User?                    @relation("invoice_master_adv_payment_received_byTouser_master", fields: [adv_payment_received_by], references: [userId], onDelete: Restrict, onUpdate: Restrict, map: "invoice_master_ibfk_9")
