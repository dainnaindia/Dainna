  addeddate       DateTime?
  modifiedby      Int?
  modifieddate    DateTime?
}

model handling_charges {
  charge_id      Int           @id @default(autoincrement())
  state_id       Int?
  city           String?       @db.VarChar(255)
  project_id     Int?
  charge_in_perc Float?
  addedby        Int?
  addeddate      DateTime?
  modifiedby     Int?
  modifieddate   DateTime?
  state_master   state_master? @relation(fields: [state_id], references: [state_id], onDelete: Restrict, onUpdate: Restrict, map: "handling_charges_ibfk_1")
  project_master Project?      @relation(fields: [project_id], references: [projectId], onDelete: Restrict, onUpdate: Restrict, map: "handling_charges_ibfk_2")

  @@index([project_id])
  @@index([state_id])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
