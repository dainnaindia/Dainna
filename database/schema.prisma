  olb_id                                                            Int?
  project_id                                                        Int?
  advocate_id                                                       Int?
  customer_id                                                       String?                  @db.VarChar(255)
  state_id                                                          Int?
  inv_no                                                            String?                  @db.VarChar(255)
  invoice_no                                                        String?                  @db.VarChar(255)
  invoice_date                                                      DateTime?                @db.Date
  size_width                                                        Decimal?                 @default(0) @db.Decimal(10, 0)
  size_height                                                       Decimal?                 @default(0) @db.Decimal(10, 0)
  size                                                              Decimal?                 @default(0) @db.Decimal(10, 0)
  rate                                                              Float?
  final_rate                                                        Float?
  total                                                             Float?
  sgst_rate                                                         Decimal?                 @default(0.00) @db.Decimal(10, 2)
  sgst_amount                                                       Decimal?                 @default(0.00) @db.Decimal(10, 2)
  cgst_rate                                                         Decimal?                 @default(0.00) @db.Decimal(10, 2)
  cgst_amount                                                       Decimal?                 @default(0.00) @db.Decimal(10, 2)
  igst_rate                                                         Decimal?                 @default(0.00) @db.Decimal(10, 2)
  igst_amount                                                       Decimal?                 @default(0.00) @db.Decimal(10, 2)
  handling_charge_rate                                              Decimal?                 @default(0.00) @db.Decimal(10, 2)
  handling_charge_amount                                            Decimal?                 @default(0.00) @db.Decimal(10, 2)
  grandtotal                                                        Decimal?                 @default(0.00) @db.Decimal(10, 2)
  adv_amount                                                        Decimal?                 @default(0.00) @db.Decimal(10, 2)
  razorpay_order_id                                                 String?                  @db.VarChar(255)
  razorpay_response                                                 String?                  @db.Text
  payment_status                                                    Int?
  payment_remarks                                                   String?                  @db.VarChar(255)
  transaction_ref_no                                                String?                  @db.VarChar(255)
  transaction_remarks                                               String?                  @db.VarChar(500)
  pg_id                                                             Int?
  adv_transaction_id                                                String?                  @db.VarChar(255)
  adv_payment_date                                                  DateTime?                @db.Date
  adv_payment_method                                                String?                  @db.VarChar(255)
  adv_payment_remarks                                               String?                  @db.VarChar(500)
  adv_payment_status                                                Int?                     @default(0)
  adv_ps_remarks                                                    String?                  @db.VarChar(255)
  adv_pay_id                                                        Int?
  addedby                                                           Int?
  addeddate                                                         DateTime?
  agent_payment_received_by                                         Int?
  agent_payment_received_date                                       DateTime?
  adv_payment_received_by                                           Int?
  adv_payment_received_date                                         DateTime?
