.env.development.local
.env.test.local
.env.production.local
.env.*
*.env
**/.env
**/.env.*
**/*.env
!**/.env.example

# TypeScript build info
*.tsbuildinfo
**/*.tsbuildinfo
next-env.d.ts
**/next-env.d.ts

# SQLite or other local databases
*.db
*.sqlite
*.sqlite3
**/backup/*.sql
